# Supabase (governanca: login e fila de aprovacao)
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude (analise dos agentes)
ANTHROPIC_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# Voibi (fonte da verdade do CRM)
VOIBI_BASE_URL=https://chat.voibi.com.br
# Empresa: kanban, contatos, etiquetas, tarefas (Configuracoes -> Empresa -> API Key da Empresa)
VOIBI_API_KEY_EMPRESA=xxxxxxxxxxxxxxxxxxxxxxxx
# Conexao: envio de mensagem/midia (fase 2, ainda nao usada nesta fase)
VOIBI_API_KEY_CONEXAO=xxxxxxxxxxxxxxxxxxxxxxxx
# Etiqueta que o agente de Qualidade aplica (precisa existir no Voibi)
VOIBI_TAG_REVISAO=Revisão CRM
# Usuario padrao para tarefas quando o agente nao define responsavel (UUID de um usuario do Voibi)
VOIBI_DEFAULT_USER_ID=
